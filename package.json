{
  "name": "chrome-history-explorer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "ingest": "bun run src/server/ingest.ts",
    "server": "bun run src/server/index.ts",
    "dev:web": "vite",
    "dev": "concurrently -k -n server,web \"bun run src/server/index.ts\" \"vite\"",
    "build": "vite build",
    "start": "bun run src/server/index.ts"
  },
  "dependencies": {
    "hono": "^4.6.14",
    "tldts": "^6.1.71"
  },
  "devDependencies": {
    "@tanstack/react-table": "^8.20.6",
    "@tanstack/react-virtual": "^3.11.2",
    "@types/bun": "^1.3.14",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "postcss": "^8.4.49",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  }
}
